{
  "name": "@agentspec/sdk",
  "version": "0.1.0",
  "description": "Official SDK for the AgentSpec protocol — validate, publish, and verify agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/schema.json','dist/schema.json')\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["agentspec", "ai-agents", "sdk", "registry"],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}
