{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pactspec.dev/schema/v1.json",
  "title": "PactSpec v1",
  "description": "Machine-readable capability declaration for AI agents",
  "type": "object",
  "required": ["specVersion", "id", "name", "version", "provider", "endpoint", "skills"],
  "properties": {
    "specVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^urn:pactspec:[a-z0-9-]+:[a-z0-9-]+$",
      "description": "e.g. urn:pactspec:acme:invoice-processor"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "maxLength": 500 },
    "provider": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":    { "type": "string" },
        "url":     { "type": "string", "format": "uri" },
        "did":     { "type": "string" },
        "contact": { "type": "string", "format": "email" }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "properties": {
            "type":   { "type": "string", "enum": ["none", "bearer", "x-agent-id", "header"] },
            "header": { "type": "string" }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "inputSchema", "outputSchema"],
        "properties": {
          "id":          { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "tags":        { "type": "array", "items": { "type": "string" } },
          "inputSchema":  { "type": "object" },
          "outputSchema": { "type": "object" },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["input", "expectedOutput"],
              "properties": {
                "description":    { "type": "string" },
                "input":          {},
                "expectedOutput": {}
              }
            }
          },
          "pricing": {
            "type": "object",
            "required": ["model", "amount", "currency"],
            "properties": {
              "model":    { "type": "string", "enum": ["per-invocation", "per-token", "per-second", "free"] },
              "amount":   { "type": "number", "minimum": 0 },
              "currency": { "type": "string", "enum": ["USD", "USDC", "SOL"] },
              "protocol": { "type": "string", "enum": ["x402", "stripe", "none"] }
            }
          },
          "sla": {
            "type": "object",
            "properties": {
              "p50LatencyMs":   { "type": "integer", "minimum": 0 },
              "p99LatencyMs":   { "type": "integer", "minimum": 0 },
              "uptimeSLA":      { "type": "number", "minimum": 0, "maximum": 1 },
              "maxConcurrency": { "type": "integer", "minimum": 1 }
            }
          },
          "testSuite": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url":  { "type": "string", "format": "uri" },
              "type": { "type": "string", "enum": ["http-roundtrip", "json-schema-validation"] }
            }
          }
        }
      }
    },
    "tags":    { "type": "array", "items": { "type": "string" } },
    "license": { "type": "string" },
    "links": {
      "type": "object",
      "properties": {
        "documentation": { "type": "string", "format": "uri" },
        "repository":    { "type": "string", "format": "uri" }
      }
    }
  }
}
